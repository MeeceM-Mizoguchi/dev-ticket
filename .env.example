VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 音声通話(WebRTC)の TURN サーバー ─────────────────────────
# 未設定でも STUN のみで動くが、Symmetric NAT(企業ファイアウォール等)の参加者は
# 原理的に P2P 接続できず「接続できませんでした」になる(BRU5-066 / BRU7-035)。
# 443/TLS(turns:)を1本入れておくと最も通りやすい。カンマ区切りで複数指定可。
#
# 【Metered 無料枠(月50GB)で用意する手順】 docs/BRU7-035-turn-setup.md も参照
#   1. https://dashboard.metered.ca/signup でアカウント作成 → アプリを1つ作成
#   2. TURN Server → Credentials の「username / password」と URL 一覧をコピー
#   3. 下記3つに貼り付ける(URLは Metered が出す標準セットをそのまま)
# TURN は P2P が失敗したときだけ中継するので、通常の通話では帯域を消費せず無料枠で十分。
VITE_TURN_URLS=turn:standard.relay.metered.ca:80,turn:standard.relay.metered.ca:80?transport=tcp,turn:standard.relay.metered.ca:443,turns:standard.relay.metered.ca:443?transport=tcp
VITE_TURN_USERNAME=your-metered-username
VITE_TURN_CREDENTIAL=your-metered-credential

# ── サーバーサイド専用（Viteのバンドルに含まれない） ─────────
# Supabase: Settings → API → service_role キー
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your_resend_api_key

# 招待メールの差出人（Resend で認証済みドメイン or onboarding@resend.dev でテスト可）
# Production: Resend でドメイン認証後に dev-ticket.com を使用
RESEND_FROM_EMAIL=Dev Ticket <noreply@dev-ticket.com>

# デプロイ後の公開URL
# Production: https://dv-ticket.com
# Staging:    https://staging.dv-ticket.com
# Local:      http://localhost:5173
PUBLIC_URL=https://dv-ticket.com

# Gemini API: https://aistudio.google.com/app/apikey でキーを発行
GEMINI_API_KEY=your-gemini-api-key

# Slack App OAuth: api.slack.com/apps でSlack Appを作成し、以下を設定する
#   OAuth & Permissions → Scopes → Bot Token Scopes: chat:write, chat:write.public
#   OAuth & Permissions → Redirect URLs に "${PUBLIC_URL}/api/slack-oauth-callback" を追加
#   例: https://dv-ticket.com/api/slack-oauth-callback
SLACK_CLIENT_ID=your-slack-app-client-id
SLACK_CLIENT_SECRET=your-slack-app-client-secret
